{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"allowImportingTsExtensions": false,
		"types": []
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/e2e.ts", "src/**/*.test.ts"]
}
