{
	"name": "@isaacwasserman/remora",
	"version": "0.2.1",
	"description": "A workflow DSL for agents — compile, execute, and visualize agent workflows",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/isaacwasserman/remora"
	},
	"license": "GPL-3.0",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/lib.js",
			"types": "./dist/lib.d.ts"
		},
		"./viewer": {
			"import": "./dist/viewer/index.js",
			"types": "./dist/viewer/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bun scripts/build.ts",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"test:e2e": "bun test src/e2e.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix --unsafe .",
		"viewer": "bun src/viewer/demo/server.ts",
		"typecheck": "tsgo --noEmit",
		"docs:api": "bunx typedoc",
		"docs:dev": "bun run docs:api && bunx vitepress dev docs",
		"docs:build": "bun run docs:api && bunx vitepress build docs",
		"docs:preview": "bunx vitepress preview docs",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"ci:release": "bun run build && npm publish --provenance --access public"
	},
	"dependencies": {
		"arktype": "^2.1.29",
		"@dagrejs/dagre": "^2.0.4",
		"@jmespath-community/jmespath": "^1.3.0"
	},
	"peerDependencies": {
		"ai": "^6.0.0",
		"@ai-sdk/provider-utils": "^4.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0",
		"@xyflow/react": "^12.0.0"
	},
	"peerDependenciesMeta": {
		"ai": {
			"optional": true
		},
		"@ai-sdk/provider-utils": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"@xyflow/react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@ai-sdk/anthropic": "^3.0.50",
		"@ai-sdk/openai": "^3.0.37",
		"@biomejs/biome": "2.4.4",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260301.1",
		"@xyflow/react": "^12.10.1",
		"ai": "^6.0.105",
		"bun-plugin-tailwind": "^0.1.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1",
		"typedoc": "^0.28.17",
		"typedoc-plugin-markdown": "^4.10.0",
		"typescript": "^5.8.0",
		"vitepress": "^1.6.4"
	}
}
