{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"allowImportingTsExtensions": false,
		"types": []
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"src/index.ts",
		"src/example-tasks.ts",
		"src/viewer/demo/**",
		"src/**/*.test.ts"
	]
}
